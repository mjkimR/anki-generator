# ─── anki-generator environment ──────────────────────────────────────────────
# Copy to `.env` (gitignored, per-machine) and edit. Everything here is OPTIONAL
# except the Azure keys when TTS_PROVIDER=azure (the default). Commented values are
# the defaults baked into src/anki_generator/config.py — uncomment only to override.

# ── Anki connection ──────────────────────────────────────────────────────────
# AnkiConnect endpoint. On WSL, an unreachable localhost auto-falls back to the
# Windows-host gateway IP, so this usually needs no change.
#ANKI_CONNECT_URL=http://localhost:8765

# Generation-only machine: set to 0 to disable ALL Anki + TTS interaction. The
# pipeline then persists cards, refreshes data/, and stops — another machine pushes
# them after a git pull. (Also accepts false/no.)
#ANKI_ENABLED=1

# ── Decks & note model (code-owned; override only the names, per-machine) ─────
#ANKI_DEFAULT_DECK=Japanese::Vocabulary    # vocab cards are born here
#ANKI_LISTENING_DECK=Japanese::Listening   # Listening cards swept here (route_listening_cards)
#ANKI_HYOGAI_DECK=Japanese::Hyogai         # Hyōgai recognition cards swept here (route_hyogai_cards)
#ANKI_NOTE_MODEL=AnkiGen JA                # repo-owned note model name

# ── TTS (ADR-0010: one provider, explicitly selected, fail closed) ────────────
# azure (default) or edge. There is NO automatic fallback between providers; a
# failure of the selected provider leaves the card pending for `sync-pending`.
#TTS_PROVIDER=azure
#TTS_DEFAULT_VOICE=ja-JP-NanamiNeural
# Required when TTS_PROVIDER=azure. Register these ONLY on the machine that pushes
# (a generation-only machine with ANKI_ENABLED=0 never runs TTS).
AZURE_SPEECH_KEY=<your-key>
AZURE_SPEECH_REGION=<your-region>
